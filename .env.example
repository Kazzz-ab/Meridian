# Required
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_studio_key_here
ALLOWED_ORIGIN=https://your-site.vercel.app

# Optional — durable, cross-instance rate limiting (anti-spam).
# If unset, an in-memory dual-window limiter is used (per serverless instance).
# Create a free Redis at https://upstash.com and paste the REST credentials.
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_rest_token
